# Copy to .env and adjust for your environment.
# docker-compose mounts this file into the container, so one copy serves both
# `python run.py` and `docker compose up`.

# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./jaikvin.db

# Postgres — bundled container (docker compose --profile local-db up):
# DATABASE_URL=postgresql+psycopg2://jaikvin:jaikvin@db:5432/jaikvin
# Postgres — hosted (Neon and similar require sslmode=require):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8090

# Signs session tokens. GENERATE A REAL ONE before deploying — anyone holding
# it can mint a valid login for any account:  openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=720

# Dev server bind — change API_PORT to switch ports (run: python run.py).
API_HOST=0.0.0.0
API_PORT=8000
RELOAD=true
