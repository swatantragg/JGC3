# Copy to .env and adjust for your environment.

# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./jaikvin.db

# Postgres (production example):
# DATABASE_URL=postgresql+psycopg2://jaikvin:jaikvin@db:5432/jaikvin

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8090

# Dev server bind — change API_PORT to switch ports (run: python run.py).
API_HOST=0.0.0.0
API_PORT=8000
RELOAD=true
