# Copy to .env for local overrides.

# Dev server port — change to switch ports easily.
VITE_PORT=5173

# Where the browser sends API calls. Leave EMPTY to use same-origin /api
# (dev: the Vite proxy in vite.config.js; prod: the nginx proxy). Set a full
# URL only if the API lives on a different host.
VITE_API_URL=

# Dev-only: where the Vite proxy forwards /api during `npm run dev`.
# Keep in sync with the backend's API_PORT.
VITE_API_PROXY=http://localhost:8000
